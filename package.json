{
  "name": "hut-reservation-mcp",
  "version": "0.1.0",
  "description": "Local-first MCP server for hut-reservation.org search, availability, and safe booking workflows.",
  "type": "module",
  "license": "MIT",
  "author": "Dominic Wörner",
  "homepage": "https://github.com/domwoe/hut-reservation-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domwoe/hut-reservation-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/domwoe/hut-reservation-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hut-reservation",
    "sac",
    "swiss-alpine-club",
    "hiking",
    "huts",
    "llm",
    "ai-agent"
  ],
  "packageManager": "pnpm@6.11.0",
  "bin": {
    "hut-reservation-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "generate:catalog": "tsx scripts/generate-bundled-catalog.mjs",
    "prepublishOnly": "pnpm build",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "evaluate:personas": "node scripts/evaluate-personas.mjs -- tsx src/index.ts",
    "smoke:mcp:dist": "node scripts/smoke-mcp.mjs -- node dist/index.js",
    "smoke:mcp:source": "node scripts/smoke-mcp.mjs -- tsx src/index.ts",
    "smoke:read": "tsx src/live-smoke.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.11"
  }
}
