# hut-reservation.org upstream
HUT_RESERVATION_BASE_URL=https://www.hut-reservation.org

# Dotenv loading is enabled by default for .env in the current working directory.
# HUT_RESERVATION_DOTENV_PATH=/absolute/path/to/.env
# HUT_RESERVATION_DOTENV_DISABLED=true

# Use "standard" for normal hut-reservation.org credentials, or "sac" for
# browser-session handoff after logging in through SAC.
HUT_RESERVATION_AUTH_MODE=standard

# Standard auth mode.
HUT_RESERVATION_USERNAME=
HUT_RESERVATION_PASSWORD=

# SAC auth mode. Copy these from DevTools after browser login:
# Application -> Cookies -> https://www.hut-reservation.org.
HUT_RESERVATION_SESSION_COOKIE=
HUT_RESERVATION_XSRF_TOKEN=

# Alternative SAC auth input. If set, SESSION and XSRF-TOKEN are parsed from here.
HUT_RESERVATION_COOKIE_HEADER=

# Local cache for hut catalog, area lookups, and booking/cancellation drafts.
# Leave blank to use ~/.cache/hut-reservation-mcp.
HUT_RESERVATION_CACHE_DIR=

# Timeout for hut-reservation.org HTTP requests in milliseconds.
HUT_RESERVATION_REQUEST_TIMEOUT_MS=15000

# Enable only when intentionally testing confirmed upstream writes.
HUT_RESERVATION_EXPERIMENTAL_WRITES=false

# Enable read-only live smoke tests.
HUT_RESERVATION_LIVE_SMOKE=false

# Optional Nominatim-compatible reverse geocoder for country/canton area cache.
# The server never uses public Nominatim implicitly; configure an explicit provider
# and follow its usage policy.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=hut-reservation-mcp/0.1.0
NOMINATIM_EMAIL=
NOMINATIM_MIN_INTERVAL_MS=1000

